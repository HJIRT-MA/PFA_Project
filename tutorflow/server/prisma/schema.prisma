generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                   @id @default(uuid())
  email             String                   @unique
  passwordHash      String?
  role              Role                     @default(STUDENT)
  googleId          String?                  @unique
  avatarUrl         String?
  createdAt         DateTime                 @default(now())
  disputesOpened    Dispute[]
  messagesReceived  Message[]                @relation("MessagesReceived")
  messagesSent      Message[]                @relation("MessagesSent")
  notifications     Notification[]
  notificationPrefs NotificationPreferences?
  reviewsAsStudent  Review[]                 @relation("StudentReviews")
  reviewsAsTutor    Review[]                 @relation("TutorReviews")
  sessionsAsStudent Session[]                @relation("StudentSessions")
  sessionsAsTutor   Session[]                @relation("TutorSessions")
  tutorProfile      TutorProfile?
}

model TutorProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  bio           String
  subjects      String[]
  hourlyRate    Float
  isVerified    Boolean  @default(false)
  availability  Json?
  averageRating Float    @default(0)
  reviewCount   Int      @default(0)
  user          User     @relation(fields: [userId], references: [id])
}

model Session {
  id                    String        @id @default(uuid())
  studentId             String
  tutorId               String
  datetime              DateTime
  durationMin           Int
  status                SessionStatus @default(PENDING)
  amountCents           Int
  stripePaymentIntentId String?
  disputes              Dispute[]
  messages              Message[]
  review                Review?
  student               User          @relation("StudentSessions", fields: [studentId], references: [id])
  tutor                 User          @relation("TutorSessions", fields: [tutorId], references: [id])
}

model Message {
  id         String    @id @default(uuid())
  senderId   String
  receiverId String
  sessionId  String?
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  receiver   User      @relation("MessagesReceived", fields: [receiverId], references: [id])
  sender     User      @relation("MessagesSent", fields: [senderId], references: [id])
  session    Session?  @relation(fields: [sessionId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  sessionId String   @unique
  studentId String
  tutorId   String
  rating    Int
  comment   String
  isFlagged Boolean  @default(false)
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
  student   User     @relation("StudentReviews", fields: [studentId], references: [id])
  tutor     User     @relation("TutorReviews", fields: [tutorId], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model NotificationPreferences {
  userId          String  @id
  emailOnBooking  Boolean @default(true)
  emailOnMessage  Boolean @default(true)
  emailOnReminder Boolean @default(true)
  pushOnBooking   Boolean @default(true)
  pushOnMessage   Boolean @default(true)
  pushOnReminder  Boolean @default(true)
  user            User    @relation(fields: [userId], references: [id])
}

model Dispute {
  id          String        @id @default(uuid())
  sessionId   String
  openedBy    String
  reason      String
  description String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  opener      User          @relation(fields: [openedBy], references: [id])
  session     Session       @relation(fields: [sessionId], references: [id])
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum SessionStatus {
  AWAITING_PAYMENT
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  NEW_MESSAGE
  SESSION_REMINDER
  NEW_REVIEW
  REVIEW_REQUEST
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}
