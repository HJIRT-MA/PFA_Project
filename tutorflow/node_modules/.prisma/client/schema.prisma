generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum SessionStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  role         Role     @default(STUDENT)
  googleId     String?  @unique
  avatarUrl    String?
  createdAt    DateTime @default(now())

  tutorProfile      TutorProfile?
  sessionsAsStudent Session[]     @relation("StudentSessions")
  sessionsAsTutor   Session[]     @relation("TutorSessions")
  messagesSent      Message[]     @relation("MessagesSent")
  messagesReceived  Message[]     @relation("MessagesReceived")
  reviewsAsStudent  Review[]      @relation("StudentReviews")
  reviewsAsTutor    Review[]      @relation("TutorReviews")
}

model TutorProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  bio        String
  subjects   String[]
  hourlyRate Float
  isVerified Boolean  @default(false)
}

model Session {
  id          String        @id @default(uuid())
  studentId   String
  tutorId     String
  student     User          @relation("StudentSessions", fields: [studentId], references: [id])
  tutor       User          @relation("TutorSessions", fields: [tutorId], references: [id])
  datetime    DateTime
  durationMin Int
  status      SessionStatus @default(PENDING)
  amountCents Int

  messages Message[]
  reviews  Review[]
}

model Message {
  id         String    @id @default(uuid())
  senderId   String
  receiverId String
  sessionId  String?
  sender     User      @relation("MessagesSent", fields: [senderId], references: [id])
  receiver   User      @relation("MessagesReceived", fields: [receiverId], references: [id])
  session    Session?  @relation(fields: [sessionId], references: [id])
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())
}

model Review {
  id        String   @id @default(uuid())
  sessionId String
  studentId String
  tutorId   String
  session   Session  @relation(fields: [sessionId], references: [id])
  student   User     @relation("StudentReviews", fields: [studentId], references: [id])
  tutor     User     @relation("TutorReviews", fields: [tutorId], references: [id])
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}
